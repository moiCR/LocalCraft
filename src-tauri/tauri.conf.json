{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalCraft",
  "version": "0.6.1",
  "identifier": "com.moiCR.LocalCraft",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalCraft",
        "width": 1280,
        "height": 720,
        "transparent": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "desktop-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "createUpdaterArtifacts": false
  }
}
